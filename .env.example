# Local secrets and overrides (copy to .env — never commit .env)
#
# Profile: test overlay (config/config.test.yaml) for pytest and Docker CI
# CLI_PROFILE=test
# CLI_ENV=test
#
# Optional full config directory override (skips profile merge)
# CLI_CONFIG_DIR=~/.config/cli
#
# Notion
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=your-notion-database-id
# NOTION_TASK_ROOT=~/github/private/tasks
#
# Backup / drive
# BACKUP_ZIP_PASSWORD=your-zip-password
# GOOGLE_DRIVE_TOKEN=ya29....
# ONEDRIVE_TOKEN=EwB....
#
# OpenCode / DeepSeek
# DEEPSEEK_API_KEY=sk-...
# OPENCODE_ATTACH=http://127.0.0.1:4096
# OPENCODE_CONFIG=~/.config/cli/opencode/opencode.json
#
# PyPI — https://pypi.org/manage/account/token/
# PYPI_API_TOKEN=pypi-...
# TESTPYPI_API_TOKEN=pypi-...
#
# Docker Hub — https://hub.docker.com/settings/security
# DOCKERHUB_USERNAME=your-dockerhub-user
# DOCKERHUB_TOKEN=dckr_pat_...
