# Local secrets (copy to .env — never commit .env)
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=your-notion-database-id
# NOTION_TASK_ROOT=~/github/private/tasks
# BACKUP_ZIP_PASSWORD=your-zip-password
# GOOGLE_DRIVE_TOKEN=ya29....
# ONEDRIVE_TOKEN=EwB....
# CLI_CONFIG_DIR=~/.config/cli
#
# OpenCode / DeepSeek (cli opencode — see docs/opencode.md)
# DEEPSEEK_API_KEY=sk-...
# OPENCODE_ATTACH=http://127.0.0.1:4096   # optional: attach to `opencode serve`
# OPENCODE_CONFIG=~/.config/cli/opencode/opencode.json
#
# PyPI publish — https://pypi.org/manage/account/token/
# PYPI_API_TOKEN=pypi-...
#
# TestPyPI (PR CI / local dry-run uploads) — https://test.pypi.org/manage/account/token/
# TESTPYPI_API_TOKEN=pypi-...
#
# Docker Hub — https://hub.docker.com/settings/security
# DOCKERHUB_USERNAME=your-dockerhub-user
# DOCKERHUB_TOKEN=dckr_pat_...
