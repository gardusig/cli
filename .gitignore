# Allowed tracked roots (do not add ignore patterns that hide these):
#   config/ docs/ scripts/ src/ tests/ .github/
#   docker/.dockerignore docker/pull-request.dockerfile docker/release.dockerfile
#
# Ephemeral link staged by gh_docker_build (canonical ignore: docker/.dockerignore)
.dockerignore
#
# --- Cursor / IDE ---
.cursor/
.idea/
.vscode/

# --- Python ---
.venv/
.uv/
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.tox/
.hypothesis/
pip-wheel-metadata/
.eggs/

# --- Tests / coverage ---
.pytest_cache/
.integration-scratch/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Build / packaging (never commit) ---
src-*/
src.egg-info/
*.whl

# --- Integration temp dirs (host leaks outside Docker scratch) ---
cli-git-*/
cli-public-*/
cli-workflow-*/
cli-tag-zip-*/
cli-outside-git-*/
cli-contest-*/
cli-*-origin.git/

# --- Secrets / local env ---
.env
.env.local
.env.*.local

# --- OS ---
.DS_Store
**/.DS_Store
.AppleDouble
._*

# --- Editor swap files ---
*~
*.swp
*.swo

# --- Logs ---
*.log
