# Allowed tracked roots (do not add ignore patterns that hide these):
#   config/ docs/ scripts/ src/ tests/ docker/ .github/
#   docker/*.dockerfile docker/.dockerignore pyproject.toml uv.lock requirements*.txt coverage-unit.ini README.md LICENSE
#
# --- Cursor / IDE ---
.cursor/
.idea/
.vscode/

# --- Python ---
.venv/
.uv/
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.tox/
.hypothesis/
pip-wheel-metadata/
.eggs/

# --- Tests / coverage ---
.pytest_cache/
.integration-scratch/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Build / packaging (never commit) ---
src-*/
src.egg-info/
*.whl

# --- Docker build context (generated from docker/.dockerignore before docker build) ---
/.dockerignore

# --- Integration temp dirs (host leaks outside Docker scratch) ---
cli-git-*/
cli-public-*/
cli-workflow-*/
cli-tag-zip-*/
cli-outside-git-*/
cli-contest-*/
cli-*-origin.git/

# --- Secrets / local env ---
.env
.env.local
.env.*.local

# --- OS ---
.DS_Store
**/.DS_Store
.AppleDouble
._*

# --- Editor swap files ---
*~
*.swp
*.swo

# --- Logs ---
*.log
