# Tag push — build artifacts and publish GitHub Release. Customize build + files for your stack.
name: release

on:
  push:
    tags:
      - "*"   # date tags; use "v*" for semver (cli)

permissions:
  contents: write

jobs:
  release:
    name: Build and publish release
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Build artifacts
        run: |
          echo "Replace with your build (npm run build, docker build, …)"

      - name: Publish GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          name: "${{ github.ref_name }}"
          generate_release_notes: true
          files: |
            path/to/artifact.zip
