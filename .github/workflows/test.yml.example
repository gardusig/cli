# PR gate — Docker unit (2m) then integration (8m). Customize Dockerfile + scripts/docker/.
name: test

on:
  pull_request:
  workflow_dispatch:

concurrency:
  group: test-${{ github.workflow }}-${{ github.event.pull_request.number || github.run_id }}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  unit:
    name: Unit tests (Docker)
    runs-on: ubuntu-latest
    timeout-minutes: 2
    steps:
      - uses: actions/checkout@v4
      - name: Unit tests
        run: |
          chmod +x scripts/test/*.sh scripts/docker/*.sh
          ./scripts/test/unit.sh

  integration:
    name: Integration tests (Docker)
    needs: unit
    runs-on: ubuntu-latest
    timeout-minutes: 8
    steps:
      - uses: actions/checkout@v4
      - name: Integration tests
        run: |
          chmod +x scripts/test/*.sh scripts/docker/*.sh
          ./scripts/test/integration.sh
